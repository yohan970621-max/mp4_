<%- include('partials/header', { pageTitle: '작품 목록' }) %>
<section class="hero-row">
  <div>
    <div class="eyebrow">FREE CHOICE VIEWING</div>
    <h1>보고 싶은 작품을 자유롭게 선택하세요</h1>
    <p class="muted">작품 순서는 계정별로 무작위 고정됩니다. 본인 작품은 자동으로 제외됩니다.</p>
  </div>
  <div class="status-badge <%= settings.evaluation_open === '1' ? 'status-badge--open' : 'status-badge--closed' %>"><%= settings.evaluation_open === '1' ? '평가 진행 중' : '평가 대기 중' %></div>
</section>
<% if (user.role === 'student') { %>
  <div class="submission-strip">
    <span><%= submission ? '내 작품 제출 완료' : '내 작품이 아직 제출되지 않았습니다.' %></span>
    <a class="button button--small button--ghost" href="/submit">내 작품 확인</a>
  </div>
<% } %>
<% if (settings.evaluation_open !== '1') { %>
  <div class="panel empty-state"><h2>아직 평가가 시작되지 않았습니다.</h2><p>제출이 끝난 뒤 관리자가 평가를 시작하면 작품을 자유롭게 시청할 수 있습니다.</p></div>
<% } else if (!videos.length) { %>
  <div class="panel empty-state"><h2>시청할 작품이 없습니다.</h2><p>제출된 작품이 있는지 관리자에게 확인하세요.</p></div>
<% } else { %>
  <div class="video-grid">
  <% videos.forEach((video, index) => { const cumulativeRate = video.duration_seconds > 0 ? Number(video.watched_seconds) / video.duration_seconds * 100 : 0; const progress = Math.min(100, cumulativeRate); %>
    <a class="video-card" href="/watch/<%= video.id %>">
      <div class="video-card__thumb">
        <img src="<%= video.thumbnail_url || ('https://i.ytimg.com/vi/' + video.youtube_id + '/hqdefault.jpg') %>" alt="">
        <% if (video.duration_seconds > 0) { %><div class="duration"><%= formatSeconds(video.duration_seconds) %></div><% } %>
      </div>
      <div class="video-card__body">
        <div class="work-label">WORK <%= String(index + 1).padStart(2, '0') %></div>
        <h2><%= video.title %></h2>
        <% if (settings.anonymous_mode !== '1') { %><p class="muted"><%= video.owner_name %></p><% } %>
        <div class="progress-row"><div class="progress"><span style="width:<%= progress.toFixed(1) %>%"></span></div><span><%= formatSeconds(video.watched_seconds) %> 누적 · <%= cumulativeRate.toFixed(1) %>%</span></div>
      </div>
    </a>
  <% }) %>
  </div>
<% } %>
<%- include('partials/footer') %>
